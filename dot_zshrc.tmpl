{{- $isManjaro := eq .chezmoi.osRelease.id "manjaro" -}}
{{ if $isManjaro -}}
USE_POWERLINE="true"
[[ -e /usr/share/zsh/manjaro-zsh-config ]] && source /usr/share/zsh/manjaro-zsh-config
[[ -e /usr/share/zsh/manjaro-zsh-prompt ]] && source /usr/share/zsh/manjaro-zsh-prompt
{{ end -}}

# completions — only init if Manjaro hasn't already
fpath+=~/.zfunc
[[ -z "$_comps" ]] && { autoload -Uz compinit; compinit; }

# history — HISTFILE/HISTSIZE/SAVEHIST already set by Manjaro config if present
HISTFILE=~/.zhistory
HISTSIZE=10000
SAVEHIST=10000

# aliases
alias ll='ls -AlFh'
alias diff='diff --color=auto'
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -I'
alias df='df -h'
alias free='free -m'

export EDITOR=nvim
export VISUAL=nvim
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# warn about missing programs
for _tool in keychain nvim; do
    command -v "$_tool" &>/dev/null || echo "dotfiles: '$_tool' is not installed" >&2
done
unset _tool

# register SSH key pairs as IdentityFile entries (no passphrase needed, loaded on first use)
_ssh_keys_conf="$HOME/.ssh/config.d/local-keys"
mkdir -p "${_ssh_keys_conf:h}"
: > "$_ssh_keys_conf"
chmod 600 "$_ssh_keys_conf"
for _pub in "$HOME/.ssh/"*.pub; do
    [[ -f "$_pub" ]] || continue
    [[ -f "${_pub%.pub}" ]] && printf 'IdentityFile %s\n' "${_pub%.pub}" >> "$_ssh_keys_conf"
done
unset _ssh_keys_conf _pub

# keychain: ensure ssh-agent is running; keys are loaded on first use via AddKeysToAgent
if command -v keychain &>/dev/null; then
    if [[ -z "$SSH_AUTH_SOCK" ]]; then
        eval "$(keychain --eval)"
    else
        keychain
    fi
fi
