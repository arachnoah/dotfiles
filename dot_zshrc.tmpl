{{- $isManjaro := eq .chezmoi.osRelease.id "manjaro" -}}
{{ if $isManjaro -}}
USE_POWERLINE="true"
[[ -e /usr/share/zsh/manjaro-zsh-config ]] && source /usr/share/zsh/manjaro-zsh-config
[[ -e /usr/share/zsh/manjaro-zsh-prompt ]] && source /usr/share/zsh/manjaro-zsh-prompt
{{ end -}}

# completions
fpath+=~/.zfunc
autoload -Uz compinit
compinit

# history
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE SHARE_HISTORY

# aliases
alias ll='ls -AlFh'
alias diff='diff --color=auto'
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -I'
alias df='df -h'
alias free='free -m'

export EDITOR=nvim
export VISUAL=nvim
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# warn about missing programs
for _tool in keychain nvim; do
    command -v "$_tool" &>/dev/null || echo "dotfiles: '$_tool' is not installed" >&2
done
unset _tool

# keychain: ensure ssh-agent is running; keys are loaded on first use via AddKeysToAgent
if command -v keychain &>/dev/null; then
    if [[ -z "$SSH_AUTH_SOCK" ]]; then
        eval "$(keychain --eval)"
    else
        keychain
    fi
fi
